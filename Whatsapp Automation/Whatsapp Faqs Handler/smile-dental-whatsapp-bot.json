    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst value = body.entry[0].changes[0].value;\nconst message = value.messages[0];\n\nconst from = message.from;\nconst text = message.text?.body || '';\nconst phoneNumberId = value.metadata.phone_number_id;\n\nreturn [{ json: { from, text, phoneNumberId } }];"
      },
      "id": "b3333333-3333-3333-3333-333333333333",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-760, 220]
    },
    {
      "parameters": {
        "resource": "sheet",
        "operation": "getAll",
        "documentId": {
          "__rl": true,
          "value": "YOUR_GOOGLE_SHEET_ID",
          "mode": "id"
        },
