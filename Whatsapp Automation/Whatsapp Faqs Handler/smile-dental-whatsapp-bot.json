      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-540, 220],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst faqText = rows.map(r => `Q: ${r.Question}\\nA: ${r.Answer}`).join('\\n\\n');\n\nreturn [{\n  json: {\n    faqText,\n    from: $('Extract Message').first().json.from,\n    text: $('Extract Message').first().json.text,\n    phoneNumberId: $('Extract Message').first().json.phoneNumberId\n  }\n}];"
      },
      "id": "b5555555-5555-5555-5555-555555555555",
      "name": "Format FAQs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-320, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama3\",\n  stream: false,\n  prompt: \"You are an AI receptionist for Smile Dental Clinic.\\n\\nUse ONLY the FAQ information provided below.\\n\\nFAQ:\\n\" + $json.faqText + \"\\n\\nUser Message:\\n\" + $json.text + \"\\n\\nInstructions:\\n- Answer only using the provided FAQ data.\\n- If the answer isn't available, reply exactly: \\\"I'm sorry, I don't have that information. I'll forward your question to our receptionist.\\\"\\n- Keep responses under 80 words.\\n- Be friendly and professional.\"\n}) }}",
        "options": {}
      },
      "id": "b6666666-6666-6666-6666-666666666666",
      "name": "Ask Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-100, 220]
    },
    {
      "parameters": {
        "jsCode": "const aiText = $input.first().json.response || \"I'm sorry, I don't have that information. I'll forward your question to our receptionist.\";\n\nreturn [{\n  json: {\n    reply: aiText.trim(),\n    to: $('Format FAQs').first().json.from,\n    phoneNumberId: $('Format FAQs').first().json.phoneNumberId\n  }\n}];"
      },
      "id": "b7777777-7777-7777-7777-777777777777",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [120, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $json.phoneNumberId }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WHATSAPP_ACCESS_TOKEN"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  messaging_product: \"whatsapp\",\n  to: $json.to,\n  type: \"text\",\n  text: { body: $json.reply }\n}) }}",
        "options": {}
      },
