    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "={{ $json.state.email }}",
        "subject": "Appointment Confirmed",
        "message": "=Hello {{ $json.state.name }},\\n\\nYour appointment has been confirmed.\\n\\nDate: {{ $json.state.date }}\\nTime: {{ $json.state.time }}\\n\\nThank you.\\nWe look forward to seeing you.",
        "options": {}
      },
      "id": "send_confirmation_email",
      "name": "Send Confirmation Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        2200,
        600
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const state = $json.state;\nconst replyText = `You're all set! Your appointment is confirmed for ${state.date} at ${state.time}. I've also sent a confirmation email to ${state.email}.`;\nreturn [{ json: { ...$json, finalReply: replyText } }];"
      },
      "id": "set_confirmation_reply",
      "name": "Set Confirmation Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        2420,
        600
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, finalReply: $json.aiReply } }];"
      },
      "id": "set_direct_reply",
      "name": "Set Direct Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        1760,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const phone = $json.phone;\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.conversations) staticData.conversations = {};\nconst state = $json.state;\nstate.history = state.history || [];\nstate.history.push({ role: 'user', content: $json.text });\nstate.history.push({ role: 'assistant', content: $json.finalReply });\nif (state.history.length > 20) state.history = state.history.slice(-20);\nstaticData.conversations[phone] = state;\n\nreturn [{ json: { ...$json } }];"
      },
      "id": "save_conversation_state",
      "name": "Save Conversation State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        2640,
        400
      ]
    },
    {
