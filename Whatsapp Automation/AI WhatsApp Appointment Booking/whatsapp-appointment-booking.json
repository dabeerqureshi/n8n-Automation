    {
      "parameters": {
        "jsCode": "const phone = $json.phone;\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.conversations) staticData.conversations = {};\nconst state = staticData.conversations[phone] || {\n  intent: null,\n  date: null,\n  time: null,\n  time_range: null,\n  selected_slot: null,\n  name: null,\n  email: null,\n  status: 'new',\n  history: []\n};\n\nreturn [{\n  json: {\n    ...$json,\n    state\n  }\n}];"
      },
      "id": "load_conversation_state",
      "name": "Load Conversation State",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        660,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const systemPrompt = `You are a friendly WhatsApp appointment booking assistant.\nGuide users through booking appointments naturally.\n\nRules:\n- Speak conversationally, ask ONE question at a time.\n- Understand natural language dates/times, convert dates to YYYY-MM-DD and times to 24h HH:MM.\n- Never ask for info already provided (see known state below).\n- If date is missing, ask for the date. If time is missing, ask for preferred time or time_range (morning/afternoon/evening).\n- If a calendar check is needed, set action to \"CHECK_CALENDAR\".\n- If slot confirmed available and name is missing, ask for full name with action \"REPLY\".\n- After name is known and email missing, ask for email with action \"REPLY\".\n- Once name, email, date and time are all known, set action \"CREATE_EVENT\".\n- Never mention APIs, Google Calendar, n8n, or internal systems.\n\nRespond ONLY with valid JSON, no extra text, in this exact shape:\n{\n  \"action\": \"REPLY\" | \"CHECK_CALENDAR\" | \"CREATE_EVENT\",\n  \"reply\": \"message to send the user, or null if action is CHECK_CALENDAR/CREATE_EVENT and reply will be generated after backend result\",\n  \"date\": \"YYYY-MM-DD or null\",\n  \"time\": \"HH:MM or null\",\n  \"time_range\": \"morning|afternoon|evening or null\",\n  \"name\": \"string or null\",\n  \"email\": \"string or null\"\n}`;\n\nconst state = $json.state;\nconst history = state.history || [];\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  { role: 'system', content: `Known state so far: ${JSON.stringify(state)}` },\n  ...history,\n  { role: 'user', content: $json.text }\n];\n\nreturn [{ json: { ...$json, ollamaMessages: messages } }];"
      },
      "id": "build_ollama_messages",
      "name": "Build Ollama Messages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        880,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3.1', messages: $json.ollamaMessages, stream: false, format: 'json' }) }}",
        "options": {}
      },
      "id": "call_ollama",
      "name": "Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "let content = ($json.message && $json.message.content) || '{}';\nlet parsed;\ntry {\n  parsed = JSON.parse(content);\n} catch (e) {\n  parsed = { action: 'REPLY', reply: \"Sorry, could you rephrase that?\" };\n}\n\nconst prev = $('Load Conversation State').first().json;\nconst state = prev.state;\n\nif (parsed.date) state.date = parsed.date;\nif (parsed.time) state.time = parsed.time;\nif (parsed.time_range) state.time_range = parsed.time_range;\nif (parsed.name) state.name = parsed.name;\nif (parsed.email) state.email = parsed.email;\nstate.status = parsed.action;\n\nreturn [{\n  json: {\n    ...prev,\n    action: parsed.action,\n    aiReply: parsed.reply,\n    state\n  }\n}];"
      },
      "id": "parse_ai_response",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        1320,
        400
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "id": "r1",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "CHECK_CALENDAR",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "CHECK_CALENDAR"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "id": "r2",
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "CREATE_EVENT",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "CREATE_EVENT"
            }
          ]
        },
        "fallbackOutput": "extra",
        "options": {}
      },
      "id": "route_action",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1540,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const state = $json.state;\nconst day = state.date || new Date(Date.now() + 86400000).toISOString().slice(0, 10);\nconst timeMin = `${day}T00:00:00`;\nconst timeMax = `${day}T23:59:59`;\nreturn [{ json: { ...$json, day, timeMin, timeMax } }];"
      },
      "id": "prepare_freebusy_range",
      "name": "Prepare FreeBusy Range",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        1760,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/freeBusy",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ timeMin: $json.timeMin, timeMax: $json.timeMax, timeZone: 'UTC', items: [{ id: 'primary' }] }) }}",
        "options": {}
      },
      "id": "get_freebusy",
      "name": "Get FreeBusy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1980,
        200
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const busy = ($json.calendars && $json.calendars.primary && $json.calendars.primary.busy) || [];\nconst state = $('Load Conversation State').first().json.state;\nconst day = $json.day;\n\nconst workStart = 9, workEnd = 17, slotMin = 30;\nlet slots = [];\nfor (let h = workStart; h < workEnd; h++) {\n  for (let m = 0; m < 60; m += slotMin) {\n    const start = new Date(`${day}T${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:00`);\n    const end = new Date(start.getTime() + slotMin * 60000);\n    const overlaps = busy.some(b => {\n      const bs = new Date(b.start), be = new Date(b.end);\n      return start < be && end > bs;\n    });\n    if (!overlaps) slots.push(`${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`);\n  }\n}\n\nconst range = state.time_range;\nif (range === 'morning') slots = slots.filter(s => s < '12:00');\nif (range === 'afternoon') slots = slots.filter(s => s >= '12:00' && s < '17:00');\nif (range === 'evening') slots = slots.filter(s => s >= '17:00');\n\nconst top3 = slots.slice(0, 3);\nconst listText = top3.map(s => `\u2022 ${s}`).join('\\n');\nconst replyText = top3.length\n  ? `Here are the available times:\\n\\n${listText}\\n\\nWhich works best for you?`\n  : `Sorry, no slots are available then. Could you try another day?`;\n\nreturn [{ json: { ...$json, finalReply: replyText, availableSlots: top3 } }];"
      },
      "id": "compute_available_slots",
      "name": "Compute Available Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        2200,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const state = $json.state;\nconst start = `${state.date}T${state.time}:00`;\nconst startDate = new Date(start);\nconst end = new Date(startDate.getTime() + 30 * 60000);\nconst pad = n => String(n).padStart(2, '0');\nconst endStr = `${state.date}T${pad(end.getHours())}:${pad(end.getMinutes())}:00`;\n\nreturn [{\n  json: {\n    ...$json,\n    eventBody: {\n      summary: `Appointment - ${state.name}`,\n      description: 'Booked via WhatsApp AI Assistant',\n      start: { dateTime: start },\n      end: { dateTime: endStr },\n      attendees: [{ email: state.email }]\n    }\n  }\n}];"
      },
      "id": "prepare_event_body",
      "name": "Prepare Event Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        1760,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.googleapis.com/calendar/v3/calendars/primary/events",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleCalendarOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.eventBody) }}",
        "options": {}
      },
      "id": "create_calendar_event",
      "name": "Create Calendar Event",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1980,
        600
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "",
