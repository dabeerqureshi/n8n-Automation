    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst entry = body && body.entry && body.entry[0];\nconst change = entry && entry.changes && entry.changes[0];\nconst value = change && change.value;\nconst message = value && value.messages && value.messages[0];\n\nif (!message) {\n  return [{ json: { noMessage: true } }];\n}\n\nconst phone = message.from;\nconst name = (value.contacts && value.contacts[0] && value.contacts[0].profile && value.contacts[0].profile.name) || 'Customer';\nconst phoneNumberId = value.metadata && value.metadata.phone_number_id;\nlet text = '';\nif (message.type === 'text') {\n  text = message.text.body;\n} else {\n  text = '[unsupported message type]';\n}\n\nreturn [{\n  json: {\n    noMessage: false,\n    phone,\n    name,\n    phoneNumberId,\n    text,\n    messageId: message.id\n  }\n}];"
      },
      "id": "extract_message",
      "name": "Extract Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        220,
        150
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
