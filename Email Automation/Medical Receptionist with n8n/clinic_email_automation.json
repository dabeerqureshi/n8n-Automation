      "id": "patient-email-trigger",
      "name": "Patient Email Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [
        220,
        380
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\n\nlet body = '';\nif (item.html) {\n  body = item.html\n    .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n    .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n} else {\n  body = (item.text || item.snippet || '').replace(/\\r\\n/g, '\\n');\n}\n\n// strip quoted replies / signatures (best effort)\nbody = body.split(/On .+ wrote:/)[0];\nbody = body.split(/-----Original Message-----/)[0];\nbody = body.split(/\\n--\\s*\\n/)[0];\nbody = body.trim();\n\nreturn [{\n  json: {\n    from: item.from || item['From'] || '',\n    subject: item.subject || item['Subject'] || '(no subject)',\n    cleanBody: body || '(empty message)',\n    messageId: item.id || item.messageId || '',\n    threadId: item.threadId || ''\n  }\n}];"
      },
      "id": "clean-email",
      "name": "Clean Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        380
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/chat",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama3.1\",\n  stream: false,\n  format: \"json\",\n  messages: [\n    { role: \"system\", content: \"You are an intake assistant for a medical clinic. Read the patient email and return ONLY a valid JSON object with keys: patient_name, intent (one of: Appointment Booking, Appointment Cancellation, Appointment Reschedule, Insurance Question, Prescription Refill, Medical Records, Lab Results, General Question, Billing Question, Emergency), doctor, date, time, insurance, urgency (Normal, High, Emergency), summary. If a field is unknown use an empty string.\" },\n    { role: \"user\", content: \"Subject: \" + $json.subject + \"\\n\\nBody: \" + $json.cleanBody }\n  ]\n}) }}",
        "options": {}
      },
      "id": "ai-extract-intent",
      "name": "AI Extract Intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        380
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "let content = '{}';\ntry {\n  content = $json.message.content;\n} catch (e) {\n  content = '{}';\n}\n\nlet data = {};\ntry {\n  data = JSON.parse(content);\n} catch (e) {\n  data = {};\n}\n\nconst intent = (data.intent || 'General Question').toString();\nconst source = $('Clean Email').first().json;\n\nreturn [{\n  json: {\n    patient_name: data.patient_name || 'Unknown',\n    intent: intent,\n    intent_key: intent.toLowerCase(),\n    doctor: data.doctor || '',\n    date: data.date || '',\n    time: data.time || '',\n    insurance: data.insurance || '',\n    urgency: data.urgency || 'Normal',\n    summary: data.summary || '',\n    from: source.from,\n    subject: source.subject,\n    cleanBody: source.cleanBody\n  }\n}];"
      },
      "id": "parse-ai-json",
      "name": "Parse AI JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        380
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json.urgency }}",
              "rightValue": "Emergency",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            },
            {
              "id": "cond2",
              "leftValue": "={{ $json.intent_key }}",
              "rightValue": "emergency",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "is-emergency",
      "name": "Is Emergency?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1100,
        380
      ]
    },
