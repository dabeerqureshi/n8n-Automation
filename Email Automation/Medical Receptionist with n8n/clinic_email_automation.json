    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Update this mapping with your clinic's real Google Calendar IDs.\nconst calendarMap = {\n  'dr. sarah': 'sarah@yourclinic.com',\n  'dr. james': 'james@yourclinic.com'\n};\n\nconst doctorKey = ($json.doctor || '').toLowerCase().trim();\nconst calendarId = calendarMap[doctorKey] || 'primary';\n\nreturn [{\n  json: {\n    ...$json,\n    calendarId\n  }\n}];"
      },
      "id": "map-doctor-to-calendar",
      "name": "Map Doctor to Calendar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        120
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "calendar": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $json.calendarId }}"
        },
        "timeMin": "={{ $now.toISO() }}",
        "timeMax": "={{ $now.plus({ days: 7 }).toISO() }}",
        "options": {}
      },
      "id": "check-doctor-availability",
      "name": "Check Doctor Availability",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.2,
      "position": [
        1760,
        120
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const events = $input.all().map(i => i.json);\nconst source = $('Map Doctor to Calendar').first().json;\n\n// Simple heuristic: fewer than 5 events in the next 7 days = likely open.\nconst isAvailable = events.length < 5;\n\nreturn [{\n  json: {\n    ...source,\n    availability_note: isAvailable\n      ? `Requested slot appears open (${source.date} ${source.time}).`\n      : `Requested slot may be busy - ${events.length} events already booked in that window; suggest alternative times.`\n  }\n}];"
      },
      "id": "determine-available-slot",
      "name": "Determine Available Slot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1980,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/chat",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama3.1\",\n  stream: false,\n  messages: [\n    { role: \"system\", content: \"You are a warm, professional medical clinic receptionist. Write a concise email reply to the patient using only the facts provided. Never invent medical advice or availability. Sign off as 'Reception Team'.\" },\n    { role: \"user\", content: \"Patient name: \" + $json.patient_name + \"\\nIntent: \" + $json.intent + \"\\nDoctor: \" + ($json.doctor || \"N/A\") + \"\\nDate: \" + ($json.date || \"N/A\") + \"\\nTime: \" + ($json.time || \"N/A\") + \"\\nInsurance: \" + ($json.insurance || \"N/A\") + \"\\nAvailability note: \" + ($json.availability_note || \"N/A\") + \"\\nPatient summary: \" + $json.summary + \"\\nOriginal message: \" + $json.cleanBody }\n  ]\n}) }}",
        "options": {}
      },
      "id": "generate-ai-reply",
      "name": "Generate AI Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2200,
        380
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "let replyText = '';\ntry {\n  replyText = $json.message.content;\n} catch (e) {\n  replyText = 'Thank you for contacting our clinic. A team member will follow up with you shortly.';\n}\n\nconst original = $('Parse AI JSON').first().json;\n\nreturn [{\n  json: {\n    to: original.from,\n    subject: 'Re: ' + (original.subject || 'Your message to the clinic'),\n    body: replyText,\n    patient_name: original.patient_name,\n    intent: original.intent,\n    urgency: original.urgency\n  }\n}];"
      },
