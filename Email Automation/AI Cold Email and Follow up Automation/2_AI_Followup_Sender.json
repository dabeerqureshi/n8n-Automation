          "value": "Clinics",
          "mode": "list",
          "cachedResultName": "Clinics"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["Email"],
          "value": {
            "Email": "={{ $('Check For Reply').item.json['Email'] }}",
            "Follow-up Count": "={{ $('Check For Reply').item.json.followUpNumber }}",
            "Last Follow-up Date": "={{ $now.format('yyyy-MM-dd') }}"
          }
        },
        "options": {}
      },
      "id": "updatesheet-fu",
      "name": "Update Sheet (Follow-up Sent)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1260, 20],
      "credentials": {
